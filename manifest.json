{
    "manifest_version": 3,
    "name": "IIMBx Transcript Downloader",
    "version": "1.0.0",
    "description": "Download all transcript PDFs from IIMBx courses",
    "permissions": [
        "downloads",
        "storage",
        "unlimitedStorage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://apps.iimbx.edu.in/*",
        "https://iimbx.edu.in/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://apps.iimbx.edu.in/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://iimbx.edu.in/*"
            ],
            "js": [
                "iframe_content.js"
            ],
            "all_frames": true,
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}